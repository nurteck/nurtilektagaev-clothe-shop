# Database (локально — docker compose; на Render — из панели БД)
DATABASE_URL="postgresql://oshop:oshop123@localhost:5432/oshop?schema=public"

# Server
PORT=4000
NODE_ENV=development
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Client (локально через vite proxy можно не указывать — будет /api)
VITE_API_URL=http://localhost:4000/api
VITE_WHATSAPP_PHONE=996553343210

# Render: подключите репозиторий → Blueprint (render.yaml) → создастся oshop + PostgreSQL
# После деплоя один раз: npm run db:seed --workspace=server (или создайте продавца вручную)